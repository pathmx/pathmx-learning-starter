{
  "name": "my-pathmx-learning-space",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "pathmxCompatibility": {
    "baseline": "0.1.21",
    "updatePolicy": "latest-after-verification"
  },
  "scripts": {
    "play": "pathmx play --print-url",
    "play:open": "pathmx play --print-url --open",
    "build": "pathmx build --clean",
    "check": "bun run scripts/check.ts",
    "check:candidate": "bun run scripts/check.ts --candidate"
  },
  "dependencies": {
    "@fellowhumans/pathmx": "0.1.21"
  }
}
